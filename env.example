import React, { useState, useEffect } from 'react';
import { Link } from 'react-router-dom';
import { db, handleFirestoreError, OperationType } from '../firebase';
import { collection, query, orderBy, onSnapshot } from 'firebase/firestore';
import { MitigationAction } from '../types';
import { CheckCircle2, Clock, ChevronRight, Search, User } from 'lucide-react';
import { clsx, type ClassValue } from 'clsx';
import { twMerge } from 'tailwind-merge';

function cn(...inputs: ClassValue[]) {
  return twMerge(clsx(inputs));
}

const MitigationActionList: React.FC = () => {
  const [actions, setActions] = useState<MitigationAction[]>([]);
  const [loading, setLoading] = useState(true);
  const [searchTerm, setSearchTerm] = useState('');

  useEffect(() => {
    const q = query(collection(db, 'mitigationActions'), orderBy('createdAt', 'desc'));
    const unsubscribe = onSnapshot(q, (querySnap) => {
      const actionsData = querySnap.docs.map(doc => ({ id: doc.id, ...doc.data() } as MitigationAction));
      setActions(actionsData);
      setLoading(false);
    }, (err) => {
      handleFirestoreError(err, OperationType.LIST, 'mitigationActions');
      setLoading(false);
    });
    return unsubscribe;
  }, []);

  const filteredActions = actions.filter(a => 
    a.summary.toLowerCase().includes(searchTerm.toLowerCase()) ||
    a.divisionInCharge.toLowerCase().includes(searchTerm.toLowerCase())
  );

  return (
    <div className="p-8">
      <div className="mb-8">
        <h1 className="text-3xl font-bold text-zinc-100">Mitigation Actions</h1>
        <p className="text-zinc-500 mt-1">Track the progress of risk remediation plans.</p>
      </div>

      <div className="flex gap-4 mb-6">
        <div className="flex-1 relative">
          <Search className="absolute left-4 top-1/2 -translate-y-1/2 text-zinc-500" size={20} />
          <input
            type="text"
            placeholder="Search actions or divisions..."
            value={searchTerm}
            onChange={(e) => setSearchTerm(e.target.value)}
            className="w-full bg-zinc-900 border border-zinc-800 rounded-2xl pl-12 pr-4 py-3 text-zinc-100 focus:outline-none focus:border-emerald-500 transition-colors"
          />
        </div>
      </div>

      <div className="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-6">
        {loading ? (
          <div className="col-span-full text-center py-12 text-zinc-500">Loading actions...</div>
        ) : filteredActions.length === 0 ? (
          <div className="col-span-full text-center py-12 text-zinc-500">No actions found.</div>
        ) : (
          filteredActions.map((action) => (
            <div key={action.id} className="bg-zinc-900 rounded-3xl border border-zinc-800 p-6 hover:border-emerald-500/50 transition-all group">
              <div className="flex justify-between items-start mb-4">
                <div className="w-10 h-10 bg-emerald-500/10 rounded-xl flex items-center justify-center text-emerald-500">
                  <CheckCircle2 size={24} />
                </div>
                <span className={cn(
                  "px-3 py-1 rounded-full text-[10px] font-bold uppercase tracking-widest",
                  action.actualStatus === 'completed' ? 'bg-emerald-500/10 text-emerald-500' :
                  action.actualStatus === 'deleted' ? 'bg-red-500/10 text-red-500' :
                  'bg-amber-500/10 text-amber-500'
                )}>
                  {action.actualStatus}
                </span>
              </div>
              
              <h3 className="text-lg font-bold text-zinc-100 mb-2 group-hover:text-emerald-500 transition-colors line-clamp-1">{action.summary}</h3>
              <p className="text-sm text-zinc-500 mb-6 line-clamp-2">{action.description}</p>
              
              <div className="space-y-3 pt-6 border-t border-zinc-800">
                <div className="flex items-center justify-between text-xs">
                  <span className="text-zinc-500 flex items-center gap-1.5 uppercase tracking-wider font-bold">
                    <User size={14} />
                    Division
                  </span>
                  <span className="text-zinc-300 font-medium">{action.divisionInCharge}</span>
                </div>
                <div className="flex items-center justify-between text-xs">
                  <span className="text-zinc-500 flex items-center gap-1.5 uppercase tracking-wider font-bold">
                    <Clock size={14} />
                    Due Date
                  </span>
                  <span className="text-zinc-300 font-medium">{action.dueDate}</span>
                </div>
              </div>
              
              <Link 
                to={`/events/${action.riskEventId}`}
                className="mt-6 w-full py-3 bg-zinc-800 hover:bg-zinc-700 text-zinc-100 text-xs font-bold rounded-xl transition-all flex items-center justify-center gap-2"
              >
                View Related Event
                <ChevronRight size={14} />
              </Link>
            </div>
          ))
        )}
      </div>
    </div>
  );
};

export default MitigationActionList;
